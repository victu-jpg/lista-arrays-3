let v = [];
for (let i = 0; i < 5; i++){
  v[i] = +prompt();
}
let maior = v[0], menor = v[0];
let posMaior = 0, posMenor = 0;
for (let i = 1; i < v.length; i++){
  if (v[i] > maior){
    maior = v[i];
    posMaior = i;
  }
  if (v[i] < menor){
    menor = v[i];
    posMenor = i;
  }
}
let temp = v[posMaior];
v[posMaior] = v[posMenor];
v[posMenor] = temp;
alert(v);
